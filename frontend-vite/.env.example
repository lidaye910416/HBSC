# Production URL of the separately-deployed MiniCast frontend (embed mode).
# MUST be a distinct origin from hbsc — a same-origin /labs/minicast path is
# this app's own React Router route and would cause infinite iframe nesting.
# Consumed by src/labs/MiniCastLab.tsx at build time.
VITE_MINICAST_URL=https://minicast.example.com/?embed=1
