# 复制为 .env 并填入真实值
# 生成密码哈希：python3 -m scripts.create_admin <username> <password>

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# JWT 配置（生产环境必须修改）
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRE_HOURS=8

# 上传配置
UPLOAD_DIR=./uploads
# Per-class size caps. Images are Pillow-validated (5 MB reasonable);
# .docx files are zips with embedded media, commonly 10-50 MB.
IMAGE_MAX_SIZE_MB=5
DOCX_MAX_SIZE_MB=50
UPLOAD_ALLOWED_MIMES=image/png,image/jpeg,image/webp,image/gif

# AI 图像生成（minimax 平台）
# 留空则使用 PIL 占位图（带 prompt 文字的渐变图）
# 设置后端会调用真实 API
MINIMAX_TOKEN=
MINIMAX_API_URL=https://api.minimax.chat/v1/image/generation
MINIMAX_MODEL=image-01
