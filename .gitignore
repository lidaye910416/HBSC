# ── Python ───────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ── Node / frontend build ──────────────────────
node_modules/
dist/
build/
.next/
.turbo/
.parcel-cache/
.vite/
*.tsbuildinfo
.npm/
.eslintcache

# ── Environment / secrets (NEVER commit) ──────
.env
.env.local
.env.*.local
**/.env
!backend/.env.example

# ── Database / uploaded media ──────────────────
*.db
*.sqlite
*.sqlite3
backend/research.db
backend/uploads/
!backend/uploads/.gitkeep

# ── OS / editor cruft ──────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs / temp ────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tmp

# ── Coverage / test artifacts ─────────────────
coverage/
.nyc_output/
*.lcov
skills-lock.json

# ── Dev runtime / tooling caches ─────────────
# dev-supervisor / uvicorn / vite PID files
.dev-pids/
# superpowers brainstorm/spec caches
.superpowers/
# git worktree directories (project-local isolation)
.worktrees/
# Playwright test artifacts (root + per-package)
test-results/
frontend-vite/test-results/
frontend-vite/playwright-report/

# ── Deploy artifacts (release/) ──────────────
# Commit manifests + docs; never secrets or binary tarballs
release/.env
release/hbsc-backend.tar
release/hbsc-frontend.tar

# ── Soft-copyright artifacts (regeneratable output + binaries) ────
# Build script: scripts/build_soft_copyright_csv.py
# Hand-written .md inputs ARE committed; binaries and the generated CSV are not.
soft-copyright/*.csv
soft-copyright/*.docx
soft-copyright/*.pdf
soft-copyright/manual-assets/

# ── Claude Code local state (never commit) ─────
.claude/
